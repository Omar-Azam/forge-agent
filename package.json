{
  "name": "@omar-azam/forge-agent",
  "version": "2.0.0",
  "description": "Forge Agent — Autonomous AI coding via browser automation. No API key needed.",
  "main": "src/index.js",
  "bin": {
    "forge-agent": "src/index.js",
    "fa": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "postinstall": "node src/postinstall.js",
    "debug": "node src/index.js --debug",
    "calibrate": "node src/calibrate.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/postinstall.js",
      "!src/calibrate.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testTimeout": 15000,
    "forceExit": true
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "forge-agent",
    "ai",
    "agent",
    "browser-automation",
    "coding-agent",
    "cli",
    "llm",
    "autonomous"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Omar-Azam/forge-agent"
  },
  "homepage": "https://github.com/Omar-Azam/forge-agent#readme",
  "publishConfig": {
    "access": "public"
  }
}
