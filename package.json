{
  "name": "deepseek-browser-agent",
  "version": "1.1.0",
  "description": "AI coding agent powered by DeepSeek via browser automation — no API key needed",
  "main": "src/index.js",
  "bin": {
    "deepseek-agent": "src/index.js",
    "dsa": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "postinstall": "node src/postinstall.js",
    "debug": "node src/index.js --debug",
    "calibrate": "node src/calibrate.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/postinstall.js",
      "!src/calibrate.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testTimeout": 15000,
    "forceExit": true
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "deepseek",
    "browser-automation",
    "coding-agent",
    "cli",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "https://github.com/yourname/deepseek-browser-agent#readme"
}
